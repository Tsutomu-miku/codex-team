{
  "name": "codex-team",
  "version": "0.0.18",
  "description": "Manage multiple Codex ChatGPT auth snapshots and quota usage from the command line.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/HOOLC/codex-team#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HOOLC/codex-team.git"
  },
  "bugs": {
    "url": "https://github.com/HOOLC/codex-team/issues"
  },
  "keywords": [
    "codex",
    "chatgpt",
    "cli",
    "account",
    "quota"
  ],
  "bin": {
    "codex-team": "dist/cli.js",
    "codexm": "dist/cli.js"
  },
  "main": "./dist/main.cjs",
  "module": "./dist/main.js",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "require": "./dist/main.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "docs:readme": "node ./scripts/sync-readme-command-sections.mjs",
    "prepack": "pnpm build",
    "test": "rstest run",
    "test:watch": "rstest watch",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm test",
    "verify:full": "pnpm verify && pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@rslib/core": "^0.20.0",
    "@rstest/core": "^0.9.3",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "dayjs": "^1.11.20"
  }
}
